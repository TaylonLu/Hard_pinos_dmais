module mac (
    input wire clk,
    input wire rst,
    input wire enable,
    input wire add_bias,

    input wire signed [15:0] a,
    input wire signed [15:0] b,
    input wire signed [15:0] bias,

    output reg signed [31:0] acc
);

    wire signed [31:0] mult;

    wire signed [31:0] mult_full;

    assign mult_full = $signed(a) * $signed(b);
    assign mult = mult_full >>> 12;


    //--------------------------
    // file: mac
    //--------------------------

        integer file_mac;

        initial begin
            file_mac = $fopen("saidas/mac_output.txt", "w");
            if (file_mac == 0) begin
                $display("Erro ao abrir arquivo!");
                $finish;
            end
        end
    //--------------------------

    //--------------------------
    // file: bias
    //--------------------------

        integer file_bias;

        initial begin
            file_bias = $fopen("saidas/bias_output.txt", "w");
            if (file_bias == 0) begin
                $display("Erro ao abrir arquivo!");
                $finish;
            end
        end
    //--------------------------


    always @(posedge clk) begin

        if (rst)
            acc <= 0;
        else if (enable)begin
            $fdisplay(file_mac,"[MAC] a: %d b: %d raw_mult=: d shifted=: d", a, b, mult_full, mult);
            acc <= acc + mult;
        end
        else if (add_bias)begin
            $fdisplay(file_bias, "[BIAS] bias: %d acc(before): %d acc(after): %d",bias, acc, acc + bias);
            acc <= acc + bias;
            end
    end

endmodule